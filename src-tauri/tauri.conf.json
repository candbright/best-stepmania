{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "BestStepMania",
  "version": "1.3.6",
  "identifier": "com.beststepmania.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BestStepMania",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "backgroundColor": "#08080f"
      },
      {
        "label": "splashscreen",
        "title": "BestStepMania",
        "width": 420,
        "height": 220,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "backgroundColor": "#08080f",
        "url": "splashscreen.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' http://tauri.localhost https://tauri.localhost; style-src 'self' 'unsafe-inline' http://tauri.localhost https://tauri.localhost; img-src 'self' blob: data: asset: http://asset.localhost https://asset.localhost http://tauri.localhost https://tauri.localhost tauri:; font-src 'self' data: http://tauri.localhost https://tauri.localhost; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost http://tauri.localhost https://tauri.localhost tauri: ws://localhost:* http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "appimage", "dmg"],
    "resources": {
      "bundle-extra/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installerHooks": "./windows/nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
