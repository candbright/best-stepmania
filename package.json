{
  "name": "best-stepmania",
  "private": true,
  "version": "1.3.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist && cargo clean --profile release",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "check:fsd-boundaries": "node scripts/check-fsd-boundaries.mjs",
    "build:clean": "npm run clean && npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run tauri -- dev",
    "tauri:build": "npm run tauri -- build",
    "tauri:build:clean": "npm run clean && npm run tauri -- build",
    "prepare-nsis-win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-tauri-nsis-windows.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2",
    "pinia": "^3",
    "vue": "^3.5",
    "vue-router": "^4.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5",
    "rimraf": "^6.1.3",
    "typescript": "~5.7",
    "vite": "^6",
    "vitest": "^3.2.4",
    "vue-tsc": "^2"
  }
}
